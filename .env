# Copy this file to .env and fill only the values you need locally.
# Never commit your real .env.

# Canonical site URL used when building share links manually.
SITE_URL=https://christos-hadjinikolis.github.io

# X API
# Use a user access token that is allowed to create posts via the X API.
X_ACCESS_TOKEN=

# LinkedIn API
# LINKEDIN_AUTHOR_URN can be a person or organization URN.
# Examples:
# urn:li:person:XXXXXXXX
# urn:li:organization:XXXXXXXX
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# LinkedIn requires an explicit YYYYMM version header.
# Set this to a currently supported version from the LinkedIn Posts API docs.
LINKEDIN_VERSION=202508
